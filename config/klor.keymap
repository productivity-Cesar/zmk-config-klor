/*
 * KLOR Polydactyl (42 keys) — Custom Keymap
 *
 * Layout per half (7 cols × 3 rows + 4 thumbs):
 *
 *   Left:
 *     Outer col:  TAB (row1) | SHIFT (row2)          ← 2 keys, no row3 outer
 *     Inner cols: 5 cols × 3 rows = 15 keys
 *     Thumbs:     ALT | DEL/CTRL | ESC/NAV | SPC      ← 4 keys
 *
 *   Right:
 *     Inner cols: 5 cols × 3 rows = 15 keys
 *     Outer col:  SHIFT (row1) | ' (row2)             ← 2 keys, no row3 outer
 *     Thumbs:     RET | BSPC/SYM | - | GUI            ← 4 keys
 *
 * Total: (2+15+4) × 2 = 42 keys ✓
 *
 * Homerow mods (GACS — left hand, mirrored right):
 *   A=GUI  S=ALT  D=CTRL  F=SHIFT  |  J=SHIFT  K=CTRL  L=ALT  ;=GUI
 *
 * Layers:
 *   0 BASE   — QWERTY + GACS homerow mods
 *   1 NAV    — Arrows, numbers, brackets
 *   2 SYM    — Symbols
 *   3 FUN    — F-keys, shortcuts, game toggle
 *   4 GAME   — WASD gaming, no homerow mods
 *   5 GTEMP  — One-shot temp, auto-returns to Game after keypress
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

#define BASE  0
#define NAV   1
#define SYM   2
#define FUN   3
#define GAME  4
#define GTEMP 5

/ {
    behaviors {

        // Homerow mod — tap-preferred, safe for typing
        hm: homerow_mod {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <150>;
            flavor = "tap-preferred";
            bindings = <&kp>, <&kp>;
        };

        // Thumb hold-tap — balanced for thumb cluster
        th: thumb_ht {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <150>;
            flavor = "balanced";
            bindings = <&kp>, <&kp>;
        };

        // Layer-tap for thumbs (hold=layer, tap=key)
        lt_th: layer_tap_thumb {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <150>;
            flavor = "balanced";
            bindings = <&mo>, <&kp>;
        };
    };

    combos {
        compatible = "zmk,combos";
        // Q + W = ESC on base
        combo_esc {
            timeout-ms = <50>;
            key-positions = <2 3>;
            bindings = <&kp ESC>;
            layers = <BASE>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

// ╔══════════════════════════════════════════════════════════════════════╗
// ║  0 — BASE   QWERTY + GACS homerow mods                             ║
// ╚══════════════════════════════════════════════════════════════════════╝
//
// ┌─────┬─────┬─────┬─────┬─────┬─────┐         ┌─────┬─────┬─────┬─────┬─────┬─────┐
// │ TAB │  Q  │  W  │  E  │  R  │  T  │         │  Y  │  U  │  I  │  O  │  P  │SHFT │
// ├─────┼─────┼─────┼─────┼─────┼─────┤         ├─────┼─────┼─────┼─────┼─────┼─────┤
// │SHFT │G⌃A  │A⌃S  │C⌃D  │S⌃F  │  G  │         │  H  │S⌃J  │C⌃K  │A⌃L  │G⌃;  │  '  │
// ├─────┼─────┼─────┼─────┼─────┼─────┤         ├─────┼─────┼─────┼─────┼─────┼─────┤
// │     │Z/FN │  X  │  C  │  V  │  B  │         │  N  │  M  │  ,  │  .  │  /  │     │
// └─────┴─────┴─────┼─────┼─────┼─────┼─────┐   └─────┼─────┼─────┼─────┴─────┴─────┘
//                   │ ALT │C/DEL│N/ESC│ SPC │   │ RET │S/BSP│  -  │ GUI │
//                   └─────┴─────┴─────┴─────┘   └─────┴─────┴─────┴─────┘

        base_layer {
            display-name = "Base";
            bindings = <
// left outer   left inner 5×3                                     right inner 5×3                                    right outer
   &kp TAB      &kp Q       &kp W       &kp E        &kp R        &kp T          &kp Y   &kp U        &kp I        &kp O       &kp P        &kp LSHFT
   &kp LSHFT    &hm LGUI A  &hm LALT S  &hm LCTRL D  &hm LSHFT F  &kp G          &kp H   &hm RSHFT J  &hm RCTRL K  &hm RALT L  &hm RGUI SEMI &kp SQT
   &trans       &lt FUN Z   &kp X       &kp C        &kp V        &kp B          &kp N   &kp M        &kp COMMA    &kp DOT     &kp FSLH     &trans
// left thumbs                                                     right thumbs
                &kp LALT    &th LCTRL DEL  &lt_th NAV ESC  &kp SPACE      &kp RET  &lt_th SYM BSPC  &kp MINUS  &kp RGUI
            >;
        };

// ╔══════════════════════════════════════════════════════════════════════╗
// ║  1 — NAV    Arrows · Numbers · Brackets                            ║
// ╚══════════════════════════════════════════════════════════════════════╝
//
// ┌─────┬─────┬─────┬─────┬─────┬─────┐         ┌─────┬─────┬─────┬─────┬─────┬─────┐
// │     │     │STAB │  C  │ TAB │  {  │         │  }  │  7  │  8  │  9  │     │     │
// ├─────┼─────┼─────┼─────┼─────┼─────┤         ├─────┼─────┼─────┼─────┼─────┼─────┤
// │     │  -  │  ←  │  ↑  │  →  │  [  │         │  ]  │  4  │  5  │  6  │  0  │     │
// ├─────┼─────┼─────┼─────┼─────┼─────┤         ├─────┼─────┼─────┼─────┼─────┼─────┤
// │     │SHFT │  -  │  ↓  │  +  │  (  │         │  )  │  1  │  2  │  3  │  ;  │     │
// └─────┴─────┴─────┼─────┼─────┼─────┼─────┐   └─────┼─────┼─────┼─────┴─────┴─────┘
//                   │ ALT │C/DEL│►NAV │ SPC │   │ RET │S/BSP│  .  │ GUI │
//                   └─────┴─────┴─────┴─────┘   └─────┴─────┴─────┴─────┘

        nav_layer {
            display-name = "Nav";
            bindings = <
   &trans    &trans       &kp LS(TAB)  &kp C       &kp TAB      &kp LBRC       &kp RBRC  &kp N7  &kp N8  &kp N9  &trans    &trans
   &trans    &kp MINUS    &kp LEFT     &kp UP      &kp RIGHT    &kp LBKT       &kp RBKT  &kp N4  &kp N5  &kp N6  &kp N0    &trans
   &trans    &kp LSHFT    &kp MINUS    &kp DOWN    &kp PLUS     &kp LPAR       &kp RPAR  &kp N1  &kp N2  &kp N3  &kp SEMI  &trans
             &kp LALT     &th LCTRL DEL  &trans    &kp SPACE      &kp RET  &lt_th SYM BSPC  &kp DOT  &kp RGUI
            >;
        };

// ╔══════════════════════════════════════════════════════════════════════╗
// ║  2 — SYM    Symbols · homerow mods passthrough                     ║
// ╚══════════════════════════════════════════════════════════════════════╝
//
// ┌─────┬─────┬─────┬─────┬─────┬─────┐         ┌─────┬─────┬─────┬─────┬─────┬─────┐
// │     │     │  @  │  #  │  $  │  %  │         │  ^  │  &  │  *  │  '  │     │     │
// ├─────┼─────┼─────┼─────┼─────┼─────┤         ├─────┼─────┼─────┼─────┼─────┼─────┤
// │     │  !  │A⌃S  │C⌃D  │S⌃F  │  G  │         │  H  │S⌃J  │C⌃K  │A⌃L  │  "  │     │
// ├─────┼─────┼─────┼─────┼─────┼─────┤         ├─────┼─────┼─────┼─────┼─────┼─────┤
// │     │G⌃A  │  X  │  C  │  V  │  B  │         │  -  │  =  │  <  │  >  │HOME │     │
// └─────┴─────┴─────┼─────┼─────┼─────┼─────┐   └─────┼─────┼─────┼─────┴─────┴─────┘
//                   │ ALT │C/DEL│N/ESC│ SPC │   │ RET │►SYM │  -  │ GUI │
//                   └─────┴─────┴─────┴─────┘   └─────┴─────┴─────┴─────┘

        sym_layer {
            display-name = "Sym";
            bindings = <
   &trans    &trans       &kp AT      &kp HASH     &kp DLLR     &kp PRCNT      &kp CARET  &kp AMPS     &kp STAR     &kp SQT     &trans    &trans
   &trans    &kp EXCL     &hm LALT S  &hm LCTRL D  &hm LSHFT F  &kp G          &kp H      &hm RSHFT J  &hm RCTRL K  &hm RALT L  &kp DQT   &trans
   &trans    &hm LGUI A   &kp X       &kp C        &kp V        &kp B          &kp MINUS  &kp EQUAL    &kp LT       &kp GT      &kp HOME  &trans
             &kp LALT     &th LCTRL DEL  &lt_th NAV ESC  &kp SPACE      &kp RET  &trans  &kp MINUS  &kp RGUI
            >;
        };

// ╔══════════════════════════════════════════════════════════════════════╗
// ║  3 — FUN    F-keys · Shortcuts · Game toggle                       ║
// ╚══════════════════════════════════════════════════════════════════════╝
//
// ┌─────┬─────┬─────┬─────┬─────┬─────┐         ┌─────┬─────┬─────┬─────┬─────┬─────┐
// │     │     │  W  │  E  │  R  │GAME │         │  Y  │  U  │  I  │ END │     │     │
// ├─────┼─────┼─────┼─────┼─────┼─────┤         ├─────┼─────┼─────┼─────┼─────┼─────┤
// │     │  Q  │A⌃S  │C⌃D  │S⌃F  │  G  │         │  H  │S⌃J  │C⌃K  │ F7  │ F1  │     │
// ├─────┼─────┼─────┼─────┼─────┼─────┤         ├─────┼─────┼─────┼─────┼─────┼─────┤
// │     │►FUN │  X  │  C  │  V  │  B  │         │  N  │  M  │  <  │ F10 │ F20 │     │
// └─────┴─────┴─────┼─────┼─────┼─────┼─────┐   └─────┼─────┼─────┼─────┴─────┴─────┘
//                   │ ALT │C/DEL│N/ESC│ SPC │   │ RET │S/BSP│  -  │ GUI │
//                   └─────┴─────┴─────┴─────┘   └─────┴─────┴─────┴─────┘

        fun_layer {
            display-name = "Fun";
            bindings = <
   &trans    &trans      &kp W       &kp E        &kp R        &tog GAME      &kp Y   &kp U        &kp I    &kp END  &trans   &trans
   &trans    &kp Q       &hm LALT S  &hm LCTRL D  &hm LSHFT F  &kp G          &kp H   &hm RSHFT J  &hm RCTRL K  &kp F7  &kp F1  &trans
   &trans    &trans      &kp X       &kp C        &kp V        &kp B          &kp N   &kp M        &kp LT   &kp F10  &kp F20 &trans
             &kp LALT    &th LCTRL DEL  &lt_th NAV ESC  &kp SPACE      &kp RET  &lt_th SYM BSPC  &kp MINUS  &kp RGUI
            >;
        };

// ╔══════════════════════════════════════════════════════════════════════╗
// ║  4 — GAME   Gaming · no homerow mods · WASD cluster                ║
// ╚══════════════════════════════════════════════════════════════════════╝
//
// ┌─────┬─────┬─────┬─────┬─────┬─────┐         ┌─────┬─────┬─────┬─────┬─────┬─────┐
// │ TAB │     │  X  │  C  │  V  │ GT+ │         │  Y  │  U  │  I  │  O  │     │     │
// ├─────┼─────┼─────┼─────┼─────┼─────┤         ├─────┼─────┼─────┼─────┼─────┼─────┤
// │ ESC │     │  Q  │  W  │  E  │  R  │         │  H  │  J  │  K  │  L  │  P  │     │
// ├─────┼─────┼─────┼─────┼─────┼─────┤         ├─────┼─────┼─────┼─────┼─────┼─────┤
// │SHFT │     │  A  │  S  │  D  │  F  │         │  N  │  M  │  ,  │  .  │  ;  │     │
// └─────┴─────┴─────┼─────┼─────┼─────┼─────┐   └─────┼─────┼─────┼─────┴─────┴─────┘
//                   │ ALT │SHFT │CTRL │ SPC │   │ RET │S/BSP│  -  │ GUI │
//                   └─────┴─────┴─────┴─────┘   └─────┴─────┴─────┴─────┘
// GT+ = &sl GTEMP — one keypress then snaps back to Game

        game_layer {
            display-name = "Game";
            bindings = <
   &kp TAB   &trans    &kp X     &kp C      &kp V      &sl GTEMP      &kp Y   &kp U   &kp I      &kp O     &trans    &trans
   &kp ESC   &trans    &kp Q     &kp W      &kp E      &kp R          &kp H   &kp J   &kp K      &kp L     &kp P     &trans
   &kp LSHFT &trans    &kp A     &kp S      &kp D      &kp F          &kp N   &kp M   &kp COMMA  &kp DOT   &kp SEMI  &trans
             &kp LALT  &kp LSHFT  &kp LCTRL  &kp SPACE      &kp RET  &lt_th SYM BSPC  &kp MINUS  &kp RGUI
            >;
        };

// ╔══════════════════════════════════════════════════════════════════════╗
// ║  5 — GTEMP  One-shot · auto-returns to Game after keypress         ║
// ╚══════════════════════════════════════════════════════════════════════╝
//
// ┌─────┬─────┬─────┬─────┬─────┬─────┐         ┌─────┬─────┬─────┬─────┬─────┬─────┐
// │     │     │  1  │  2  │  3  │  T  │         │  Y  │  U  │  I  │  O  │     │     │
// ├─────┼─────┼─────┼─────┼─────┼─────┤         ├─────┼─────┼─────┼─────┼─────┼─────┤
// │     │  Z  │  4  │  5  │  6  │  G  │         │ F5  │ F7  │  K  │  L  │ CAD │     │
// ├─────┼─────┼─────┼─────┼─────┼─────┤         ├─────┼─────┼─────┼─────┼─────┼─────┤
// │     │ F10 │  O  │  Y  │  K  │BASE │         │  N  │  M  │  ,  │ F12 │ F22 │     │
// └─────┴─────┴─────┼─────┼─────┼─────┼─────┐   └─────┼─────┼─────┼─────┴─────┴─────┘
//                   │  L  │  J  │  I  │  M  │   │ RET │S/BSP│  -  │ GUI │
//                   └─────┴─────┴─────┴─────┘   └─────┴─────┴─────┴─────┘
// BASE  = &tog GAME → exits game mode back to Base
// CAD   = Ctrl+Alt+Del

        gtemp_layer {
            display-name = "GTemp";
            bindings = <
   &trans    &trans    &kp N1  &kp N2  &kp N3    &kp T          &kp Y   &kp U   &kp I      &kp O   &trans          &trans
   &trans    &kp Z     &kp N4  &kp N5  &kp N6    &kp G          &kp F5  &kp F7  &kp K      &kp L   &kp LC(LA(DEL)) &trans
   &trans    &kp F10   &kp O   &kp Y   &kp K     &tog GAME      &kp N   &kp M   &kp COMMA  &kp F12 &kp F22         &trans
             &kp L     &kp J   &kp I   &kp M              &kp RET  &lt_th SYM BSPC  &kp MINUS  &kp RGUI
            >;
        };

    };
};
